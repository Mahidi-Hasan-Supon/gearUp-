{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "target": "ES2023",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "esModuleInterop": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  },

  // "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist"
  ]
}

